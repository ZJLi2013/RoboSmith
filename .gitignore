# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Test / cache
.pytest_cache/
.coverage
htmlcov/

# Assets: keep JSON/URDF metadata, ignore large mesh/texture files
assets/generated/*
!assets/generated/.gitkeep
!assets/catalog.json
assets/gallery.html

# Large mesh/texture files in objects/ (Objaverse imports, TRELLIS.2 outputs)
assets/objects/**/*.glb
assets/objects/**/*.obj
assets/objects/**/*.stl
assets/objects/**/*.ply
assets/objects/**/*.png
assets/objects/**/*.jpg
assets/objects/**/*.mtl

# Internal docs (experiment logs, design docs, experiment plans)
docs/design.md
docs/stage-1.md
docs/stage-2.md
docs/*_exp.md
experiments.md

# Internal scripts (experiment runners, benchmarks, node-specific tools)
scripts/run_*.sh
scripts/benchmark_io.sh
scripts/sync_assets.py
scripts/patch_genesis_rocm.py

# Training / eval output
output/

# Demo results: keep PNGs for README, ignore large mesh files
demo/results/**/*.obj
demo/results/**/*.glb
demo/results/**/*.urdf
demo/results/**/*.log
